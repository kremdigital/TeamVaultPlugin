{
  "name": "team-vault-plugin",
  "version": "0.2.0",
  "description": "Self-hosted Obsidian vault synchronization with live collaboration.",
  "main": "main.js",
  "private": true,
  "license": "MIT",
  "author": "krem.digital",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "dev:vault": "node esbuild.config.mjs --watch --vault",
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "build:vault": "tsc --noEmit && node esbuild.config.mjs --vault",
    "lint": "eslint src tests scripts",
    "lint:fix": "eslint src tests scripts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cli": "tsx scripts/cli-emulator.ts",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "lib0": "^0.2.117",
    "socket.io-client": "^4.8.3",
    "y-codemirror.next": "^0.3.5",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "builtin-modules": "^5.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.4.0",
    "lint-staged": "^17.0.2",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "ws@>=8.0.0 <8.20.1": "^8.21.0"
    }
  }
}
